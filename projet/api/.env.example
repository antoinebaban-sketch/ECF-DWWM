# Copier ce fichier en ".env" et remplir les valeurs

# En local (XAMPP) : valeurs par défaut ci-dessous.
# En production (Aiven) : host/port/user/password/nom de base fournis par
# Aiven dans l'onglet "Overview" du service MySQL. Le certificat SSL requis
# par Aiven (api/aiven-ca.pem) est détecté automatiquement dès que DB_HOST
# n'est plus "localhost" — rien d'autre à configurer.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vite_et_gourmand
DB_USER=root
DB_PASS=

# Email de l'entreprise (expéditeur + destinataire des formulaires)
MAIL_FROM=noreply@viteetgourmand.fr
MAIL_NAME=Vite & Gourmand

# URL du frontend (utilisé dans les liens des emails)
APP_URL=http://localhost/ViteEtGourmand/projet/frontend

# MongoDB Atlas — utilisé uniquement pour les statistiques "commandes par menu"
# de l'espace admin (base de données non relationnelle).
# Créer un cluster gratuit sur https://cloud.mongodb.com → Connect → Drivers → PHP
# Laisser vide pour désactiver MongoDB (l'app fonctionne sans, sans ce graphique)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=vite_et_gourmand_logs

# Brevo (ex-Sendinblue) — envoi des emails automatiques en production uniquement.
# En local, laisser vide : le code utilise mail() nativement (voir helpers.php).
# Créer un compte gratuit sur https://www.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=
