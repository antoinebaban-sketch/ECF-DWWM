Options -Indexes
RewriteEngine On

# Route tous les appels /api/* vers le routeur PHP
RewriteCond %{REQUEST_URI} /api/
RewriteRule ^api/(.*)$ api/index.php [L,QSA]

# Sert le frontend à la racine (réécriture interne, pas de redirection externe :
# derrière le proxy de Render, Apache ne connaît pas son adresse publique et
# construirait une redirection cassée — voir <base> dans frontend/index.html)
RewriteRule ^$ frontend/index.html [L]
RewriteRule ^index\.html$ frontend/index.html [L]
